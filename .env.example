# UL Gear Manager - 環境変数サンプル
# ローカルは `.env` にコピーして値を埋める。
# 本番 / STG の値は Railway の Variables で設定する。

# ===== 共通 =====
# ビルド挙動（rate limit / 認証必須 / SSL）: 本番と STG は "production" に統一
NODE_ENV=development

# アプリ論理環境（UI のバナー・決済無効化・AI クォータ等の分岐で使用）
APP_ENV=development            # development | staging | production

PORT=8000

# ===== データベース =====
# Railway / 本番 / STG は DATABASE_URL を使用（SSL デフォルト on）
DATABASE_URL=
# ローカル docker-compose 用の個別指定（DATABASE_URL が空のときだけ使われる）
DB_HOST=localhost
DB_PORT=5433
DB_NAME=gear_manager
DB_USER=postgres
DB_PASSWORD=password

# ===== Cognito (サーバー側 JWT 検証) =====
# STG と本番で別 User Pool / Client を使うこと
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# ===== OpenAI =====
OPENAI_API_KEY=

# ===== Stripe =====
# STG では未設定でよい（billing ルートは APP_ENV=staging のとき 503 を返す）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
FRONTEND_URL=

# ===== Rate Limit =====
RATE_LIMIT_MAX=100
LLM_RATE_LIMIT_MAX=10

# ===== クライアント (Vite がビルド時に埋め込む VITE_* 変数) =====
# STG では staging、本番では production を指定
VITE_APP_ENV=development

# 同一オリジン配信のため空でよい（デプロイ先では省略可）
VITE_API_BASE_URL=

# サーバー側と同じ値を設定
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
